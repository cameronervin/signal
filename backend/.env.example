# --- Application -----------------------------------------------------------
SIGNAL_ENV=local
SIGNAL_LOG_LEVEL=info
SIGNAL_FRONTEND_ORIGIN=http://localhost:3000

# --- Public Data -----------------------------------------------------------
SIGNAL_USE_FIXTURES=true
SIGNAL_PUBLIC_DATA_USER_AGENT=Signal
SIGNAL_PUBLIC_DATA_CACHE_TTL_SECONDS=3600
SIGNAL_CENSUS_API_KEY=
SIGNAL_FRED_API_KEY=
SIGNAL_NEWS_API_KEY=
SIGNAL_NOMINATIM_EMAIL=

# --- Database --------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signal
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/signal

# --- Workers ---------------------------------------------------------------
SIGNAL_CELERY_BROKER_URL=redis://localhost:6379/0
SIGNAL_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LLM -------------------------------------------------------------------
SIGNAL_LLM_PROVIDER=litellm
SIGNAL_LLM_MODEL=signal-chat
SIGNAL_LITELLM_API_BASE=http://localhost:4000
SIGNAL_LITELLM_API_KEY=sk-local-litellm-master-key

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_SIGNAL_API_BASE_URL=http://127.0.0.1:8000
