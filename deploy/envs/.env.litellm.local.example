# --- LiteLLM Runtime -------------------------------------------------------
LITELLM_IMAGE_TAG=latest
LITELLM_MASTER_KEY=sk-local-litellm-master-key
LITELLM_SALT_KEY=sk-local-litellm-salt-key-change-me

# --- LiteLLM Database ------------------------------------------------------
LITELLM_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/litellm

# --- Upstream Model --------------------------------------------------------
SIGNAL_LITELLM_UPSTREAM_MODEL=openai/gpt-5.4-mini
SIGNAL_LITELLM_UPSTREAM_API_BASE=https://api.openai.com/v1
SIGNAL_LITELLM_UPSTREAM_API_KEY=replace-with-openai-api-key
