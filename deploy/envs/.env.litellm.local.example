# --- LiteLLM Runtime -------------------------------------------------------
LITELLM_IMAGE_TAG=latest
LITELLM_MASTER_KEY=sk-local-litellm-master-key
LITELLM_SALT_KEY=sk-local-litellm-salt-key-change-me

# --- LiteLLM Database ------------------------------------------------------
LITELLM_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/litellm

# --- Upstream Model --------------------------------------------------------
SIGNAL_LITELLM_UPSTREAM_MODEL=hosted_vllm/signal-demo-model
SIGNAL_LITELLM_UPSTREAM_API_BASE=http://host.docker.internal:8001/v1
SIGNAL_LITELLM_UPSTREAM_API_KEY=replace-with-provider-api-key
