# --- LiteLLM Runtime -------------------------------------------------------
LITELLM_IMAGE_TAG=latest
LITELLM_MASTER_KEY=sk-local-litellm-master-key
LITELLM_SALT_KEY=sk-local-litellm-salt-key-change-me

# --- LiteLLM Database ------------------------------------------------------
# LiteLLM runs inside Compose, so this uses the Postgres service name and
# container port. Host tools should use localhost:5433.
LITELLM_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/litellm

# --- Upstream Model --------------------------------------------------------
SIGNAL_LITELLM_UPSTREAM_MODEL=openai/gpt-5.4-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-api-key
