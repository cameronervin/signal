# Local Docker Compose defaults. Copy to `.env.local` and edit as needed.

COMPOSE_PROJECT_NAME=signal-demo

POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal
POSTGRES_HOST_PORT=5433

VALKEY_HOST_PORT=6379
LITELLM_HOST_PORT=4000

# Host-run backend settings. These mirror backend/.env.example and are here so
# the demo dependency values live beside the Compose files that expose them.
SIGNAL_ENV=local
SIGNAL_LOG_LEVEL=INFO
SIGNAL_FRONTEND_ORIGIN=http://localhost:3000
SIGNAL_USE_FIXTURES=true
SIGNAL_REPOSITORY_BACKEND=postgres
SIGNAL_DATABASE_URL=postgresql+asyncpg://signal:signal@localhost:5433/signal
SIGNAL_CREATE_DB_SCHEMA_ON_STARTUP=true
SIGNAL_AGENT_EXECUTION_BACKEND=inline
SIGNAL_CELERY_BROKER_URL=redis://localhost:6379/0
SIGNAL_CELERY_RESULT_BACKEND=redis://localhost:6379/1
SIGNAL_LLM_PROVIDER=litellm
SIGNAL_LLM_MODEL=signal-chat
SIGNAL_LITELLM_API_BASE=http://localhost:4000
SIGNAL_LITELLM_API_KEY=sk-local-litellm-master-key

NEXT_PUBLIC_SIGNAL_API_BASE_URL=http://127.0.0.1:8000
